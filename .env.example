# =============================================================================
# Configuración del Sistema Agora
# Copia este archivo como .env y completa los valores reales.
# ¡NUNCA commits reales credenciales a git!
# =============================================================================

# --- Base de datos ---
DB_HOST=127.0.0.1
DB_USER=usuario_db
DB_PASS=contraseña_segura_db
DB_NAME=db_agora
DB_PORT=3306

# --- SMTP (Gmail / otro) ---
# Si usas Gmail, genera una "Contraseña de aplicación" en tu cuenta Google.
SMTP_HOST=smtp.gmail.com
SMTP_USER=tu_correo@gmail.com
SMTP_PASS=tu_contraseña_de_aplicacion
SMTP_FROM_EMAIL=tu_correo@gmail.com
SMTP_FROM_NAME="Agora - Recuperación de contraseña"
SMTP_SECURE=tls
SMTP_PORT=587

# --- reCAPTCHA v2 (opcional) ---
# Obtén tus llaves en https://www.google.com/recaptcha/admin
RECAPTCHA_SITE_KEY=tu_site_key
RECAPTCHA_SECRET_KEY=tu_secret_key

# --- AI Chat (opcional) ---
# Proveedor: "gemini" (Google) o "openai" (OpenAI / Ollama / LM Studio)
CHAT_PROVIDER=gemini

# Para Gemini (https://ai.google.dev):
GEMINI_API_KEY=tu_api_key_gemini
# El client ID se usa como etiqueta en las solicitudes (opcional)
GEMINI_CLIENT_ID=gen-lang-client-xxxxxxxxxxxx
GEMINI_MODEL=gemini-2.0-flash

# Para OpenAI / Ollama (dejar comentado si usas Gemini):
# CHAT_API_URL=https://api.openai.com/v1/chat/completions
# CHAT_API_KEY=sk-tu_key_openai
# CHAT_MODEL=gpt-4o-mini

# --- App ---
APP_ENV=production
APP_URL=http://localhost/TuxHub
